# DeepSeek API (摘要)
DEEPSEEK_API_KEY=sk-xxxxx

# 运行环境:production 时强制要求 AUTH_TOKEN(缺失拒绝启动 fail-closed);默认 development。
# ENVIRONMENT=production
# 服务鉴权(开发可留空=全开仅限私网;生产必填):接收端须带 Authorization: Bearer <AUTH_TOKEN>
# AUTH_TOKEN=
# SSRF 纵深:是否允许下载非白名单平台(generic/未知 host)。生产默认仅放行已知平台域名,
# 显式 =1 放开任意来源。开发默认放开。
# MAGI_CONTENT_ALLOW_GENERIC=1
# 完成回调 webhook(可选):作业 completed/failed 后 POST {job_id,status} 到此 URL。
# 用于 agent 集成:指向 agent 的 /api/magi-content/callback;WEBHOOK_TOKEN 须与其
# MAGI_CONTENT_CALLBACK_TOKEN 一致。留空 = 不回调(接收端可改用轮询兜底)。
# WEBHOOK_URL=http://127.0.0.1:3922/api/magi-content/callback
# WEBHOOK_TOKEN=

# 转录后端: tingwu(默认,云端) 或 whisper(本地,免费,无需 OSS/阿里云)
# TRANSCRIBE_BACKEND=whisper
# WHISPER_MODEL=small          # tiny/base/small/medium/large-v3（tiny 质量最低，建议 small+）
# WHISPER_DEVICE=cpu           # cpu / cuda
# WHISPER_COMPUTE_TYPE=int8    # int8(CPU) / float16(GPU)
# TRANSCRIBE_LANGUAGE=zh       # 留空=自动检测；中文平台为主可设 zh 降低串语种误判

# 字幕复用：命中平台官方字幕(YouTube官方/B站AI字幕)即直接当转写，免本地重转写
# SUBTITLE_REUSE=1             # 0/false=关闭复用、一律本地转写
# SUBTITLE_USE_AUTOCAPTION=0   # 1=官方字幕缺失时也下载/复用自动字幕(机翻/ASR，质量较低)

# B站高清/大会员/付费内容 + AI 字幕：浏览器 Cookie 里的 SESSDATA 值（yutto 主下载器只认它）
# BILIBILI_SESSDATA=

# 通义听悟 REST API (语音转文字, TRANSCRIBE_BACKEND=tingwu 时需要)
TINGWU_APP_KEY=your-tingwu-appkey

# 阿里云 AccessKey (用于 API 签名 + OSS 上传)
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret

# OSS 存储桶 (音频临时存储)
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET=your-bucket-name

# 可选: 代理（YouTube 等外网；Docker 默认 host.docker.internal:7890）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# 本地直连、不用代理时设为空: HTTP_PROXY=

# 小红书 Cookie（三选一，推荐 sync 脚本）
# 隐私默认：不配下面任何一项时，绝不自动读取本机浏览器登录态（不会带上你的小红书账号）。
# 方式1 — 本机执行一次，Docker 自动读 data/xhs_cookie.txt:
#   ./scripts/sync-xhs-cookie.sh
# 方式2 — 显式开启浏览器自动读取（仅设置后才读）: XHS_COOKIE_FROM_BROWSER=chrome 或 safari
# 方式3 — 手动粘贴: XHS_COOKIE=...
# XHS_COOKIE=
# XHS_COOKIE_FROM_BROWSER=chrome

# 摘要引擎（可插拔，默认 deepseek）：claude / qwen-vl / minimax 等
# 切到支持视觉的引擎可让图文笔记直接读图，免 OCR。需配对应 key：
# SUMMARY_ENGINE=qwen-vl
# DASHSCOPE_API_KEY=your-dashscope-key   # qwen-vl
# ANTHROPIC_API_KEY=your-anthropic-key   # claude（视觉/长上下文）
# MINIMAX_API_KEY=your-minimax-key       # minimax

# 跨任务语义检索（向量库）：配置后启用 /api/search/semantic
# EMBEDDING_BACKEND=openai               # openai(兼容端点) / local(仅联调,非语义) / 空=关闭
# EMBEDDING_API_KEY=your-embedding-key
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v3      # 维度需与向量表一致(切换维度自动用独立表)
