# DeepSeek API (摘要)
DEEPSEEK_API_KEY=sk-xxxxx

# 通义听悟 REST API (语音转文字)
TINGWU_APP_KEY=your-tingwu-appkey

# 阿里云 AccessKey (用于 API 签名 + OSS 上传)
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret

# OSS 存储桶 (音频临时存储)
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET=your-bucket-name

# 可选: 代理（YouTube 等外网；Docker 默认 host.docker.internal:7890）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# 本地直连、不用代理时设为空: HTTP_PROXY=

# 小红书 Cookie（三选一，推荐 sync 脚本）
# 方式1 — 本机执行一次，Docker 自动读 data/xhs_cookie.txt:
#   ./scripts/sync-xhs-cookie.sh
# 方式2 — 指定浏览器: XHS_COOKIE_FROM_BROWSER=chrome 或 safari
# 方式3 — 手动粘贴: XHS_COOKIE=...
# XHS_COOKIE=
# XHS_COOKIE_FROM_BROWSER=chrome
